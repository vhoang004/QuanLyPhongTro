# Dependencies
node_modules/
*/node_modules/

# Environment files (NEVER commit secrets)
.env
.env.local
.env.production
backend/.env

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# IDE
.vscode/
.idea/
*.swp
*.swo
.cursor/
*.code-workspace

# OS
.DS_Store
Thumbs.db
desktop.ini

# Build outputs
backend/dist/
frontend/dist/
build/

# Coverage
coverage/
*.lcov

# Uploads (user-uploaded files - keep structure but not contents)
backend/uploads/*
!backend/uploads/.gitkeep

# Fonts (third-party assets tracked via Docker volume)
# backend/fonts/ - tracked

# Database dumps older than current
backend/database/*.sql
!backend/database/.gitkeep

# Temp / scratch
tmp/
temp/
*.tmp
*.bak
*.orig

# Test artifacts
.nyc_output/