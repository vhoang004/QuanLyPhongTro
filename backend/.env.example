# ===============================
# SERVER CONFIG
# ===============================
PORT=5000
NODE_ENV=development

# ===============================
# DATABASE CONFIG (MySQL)
# ===============================
DB_HOST=mysql
DB_PORT=3306
DB_NAME=quanlyphongtro
DB_USER=qlpt
DB_PASSWORD=change_me_in_production

# ===============================
# JWT AUTHENTICATION
# ===============================
# Generate a strong secret with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_random_48_byte_hex_string
JWT_EXPIRES_IN=7d

# ===============================
# FRONTEND URL (for CORS)
# ===============================
CLIENT_URL=http://localhost:3000

# ===============================
# EMAIL CONFIG (Nodemailer)
# ===============================
# Use a Gmail App Password (https://myaccount.google.com/apppasswords), not your account password.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password